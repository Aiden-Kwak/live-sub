{
  "version": "1.0",
  "database": {
    "type": "SQLite",
    "file": "backend/livesub.db",
    "pragmas": ["PRAGMA foreign_keys = ON;"]
  },
  "entities": [
    {
      "name": "TranslationSession",
      "table": "translation_sessions",
      "description": "번역 세션. 사용자가 번역을 시작하면 생성되고, 중지하면 ended_at이 갱신된다.",
      "fields": [
        {
          "name": "id",
          "type": "uuid",
          "column_type": "TEXT",
          "primary_key": true,
          "auto": true,
          "nullable": false,
          "description": "세션 고유 식별자 (UUID v4, TEXT로 저장)"
        },
        {
          "name": "source_language",
          "type": "string",
          "column_type": "VARCHAR(10)",
          "max_length": 10,
          "nullable": false,
          "description": "원본 언어 코드 (예: ko, en-US)"
        },
        {
          "name": "target_language",
          "type": "string",
          "column_type": "VARCHAR(10)",
          "max_length": 10,
          "nullable": false,
          "description": "번역 대상 언어 코드 (예: en, ja)"
        },
        {
          "name": "created_at",
          "type": "datetime",
          "column_type": "DATETIME",
          "nullable": false,
          "auto": true,
          "default": "datetime('now')",
          "description": "세션 생성 시각 (UTC, ISO 8601)"
        },
        {
          "name": "ended_at",
          "type": "datetime",
          "column_type": "DATETIME",
          "nullable": true,
          "default": null,
          "description": "세션 종료 시각 (NULL이면 진행 중)"
        }
      ],
      "indexes": [
        {
          "name": "idx_session_created_at",
          "fields": ["created_at"],
          "unique": false,
          "reason": "세션 목록 최신순 정렬 조회 최적화 (향후 확장 대비)"
        }
      ]
    },
    {
      "name": "TranslationLog",
      "table": "translation_logs",
      "description": "번역 기록. 각 음성 인식 final 결과의 원본 텍스트와 번역 결과를 저장한다.",
      "fields": [
        {
          "name": "id",
          "type": "integer",
          "column_type": "INTEGER",
          "primary_key": true,
          "auto_increment": true,
          "nullable": false,
          "description": "기록 고유 식별자"
        },
        {
          "name": "session_id",
          "type": "uuid",
          "column_type": "TEXT",
          "nullable": false,
          "foreign_key": "translation_sessions.id",
          "on_delete": "CASCADE",
          "description": "소속 세션 식별자"
        },
        {
          "name": "original_text",
          "type": "text",
          "column_type": "TEXT",
          "nullable": false,
          "description": "원본 음성 인식 텍스트"
        },
        {
          "name": "translated_text",
          "type": "text",
          "column_type": "TEXT",
          "nullable": false,
          "description": "번역된 텍스트"
        },
        {
          "name": "confidence",
          "type": "float",
          "column_type": "REAL",
          "nullable": true,
          "check": "confidence IS NULL OR (confidence >= 0.0 AND confidence <= 1.0)",
          "description": "음성 인식 신뢰도 (0.0~1.0, null 허용)"
        },
        {
          "name": "created_at",
          "type": "datetime",
          "column_type": "DATETIME",
          "nullable": false,
          "auto": true,
          "default": "datetime('now')",
          "description": "기록 생성 시각 (UTC, ISO 8601)"
        }
      ],
      "indexes": [
        {
          "name": "idx_log_session_id",
          "fields": ["session_id"],
          "unique": false,
          "reason": "세션별 로그 조회 시 FK 조인 최적화 (가장 빈번한 쿼리)"
        },
        {
          "name": "idx_log_created_at",
          "fields": ["created_at"],
          "unique": false,
          "reason": "로그 시간순 정렬 조회 최적화"
        }
      ]
    }
  ],
  "relations": [
    {
      "from": "TranslationLog",
      "to": "TranslationSession",
      "type": "many_to_one",
      "field": "session_id",
      "on_delete": "CASCADE",
      "description": "하나의 세션에 여러 번역 기록이 속함"
    }
  ]
}
