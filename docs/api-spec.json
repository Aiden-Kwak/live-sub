{
  "version": "1.0",
  "base_url": "/api",
  "endpoints": [
    {
      "method": "POST",
      "path": "/translate",
      "description": "텍스트를 지정 언어로 번역 (Google Translation API v2 프록시)",
      "procedure": [
        "요청 바디에서 text, source_language, target_language 추출",
        "유효성 검증: text가 비어있거나 공백만 있으면 400 반환",
        "유효성 검증: source_language, target_language가 빈 문자열이면 400 반환",
        "환경변수에서 GOOGLE_CLOUD_API_KEY 로드",
        "Google Cloud Translation API v2 호출",
        "Google API 응답에서 translatedText 추출",
        "응답 객체 구성하여 200 반환",
        "Google API 호출 실패 시 500 반환"
      ],
      "request": {
        "content_type": "application/json",
        "fields": [
          {
            "name": "text",
            "type": "string",
            "required": true,
            "description": "번역할 원본 텍스트"
          },
          {
            "name": "source_language",
            "type": "string",
            "required": true,
            "max_length": 10,
            "description": "원본 언어 코드 (예: ko, en)"
          },
          {
            "name": "target_language",
            "type": "string",
            "required": true,
            "max_length": 10,
            "description": "번역 대상 언어 코드 (예: en, ja)"
          }
        ]
      },
      "responses": {
        "200": {
          "description": "번역 성공",
          "fields": [
            { "name": "translated_text", "type": "string", "description": "번역된 텍스트" },
            { "name": "source_language", "type": "string", "description": "원본 언어 코드" },
            { "name": "target_language", "type": "string", "description": "번역 대상 언어 코드" }
          ]
        },
        "400": { "description": "text가 비어있거나 언어 코드가 유효하지 않은 경우" },
        "500": { "description": "Google Translation API 호출 실패" }
      }
    },
    {
      "method": "GET",
      "path": "/languages",
      "description": "지원되는 언어 목록 반환",
      "procedure": [
        "환경변수에서 GOOGLE_CLOUD_API_KEY 로드",
        "Google Cloud Translation API v2 언어 목록 조회",
        "응답에서 언어 코드와 이름 목록 추출",
        "languages 배열로 200 반환",
        "Google API 호출 실패 시 500 반환"
      ],
      "request": {
        "content_type": null,
        "fields": []
      },
      "responses": {
        "200": {
          "description": "언어 목록 조회 성공",
          "fields": [
            {
              "name": "languages",
              "type": "array",
              "description": "언어 목록",
              "items": {
                "fields": [
                  { "name": "code", "type": "string", "description": "언어 코드" },
                  { "name": "name", "type": "string", "description": "언어 이름 (영어)" }
                ]
              }
            }
          ]
        },
        "500": { "description": "Google Translation API 호출 실패" }
      }
    },
    {
      "method": "POST",
      "path": "/sessions",
      "description": "새 번역 세션 생성",
      "procedure": [
        "요청 바디에서 source_language, target_language 추출",
        "유효성 검증: 두 필드 모두 비어있지 않은지 확인",
        "UUID v4 생성",
        "created_at을 현재 UTC 시각으로 설정",
        "DB에 TranslationSession INSERT",
        "생성된 세션 객체를 201 반환"
      ],
      "request": {
        "content_type": "application/json",
        "fields": [
          {
            "name": "source_language",
            "type": "string",
            "required": true,
            "max_length": 10,
            "description": "원본 언어 코드"
          },
          {
            "name": "target_language",
            "type": "string",
            "required": true,
            "max_length": 10,
            "description": "번역 대상 언어 코드"
          }
        ]
      },
      "responses": {
        "201": {
          "description": "세션 생성 성공",
          "fields": [
            { "name": "id", "type": "uuid", "description": "세션 고유 식별자" },
            { "name": "source_language", "type": "string", "description": "원본 언어 코드" },
            { "name": "target_language", "type": "string", "description": "번역 대상 언어 코드" },
            { "name": "created_at", "type": "datetime", "description": "세션 생성 시각 (ISO 8601)" }
          ]
        },
        "400": { "description": "source_language 또는 target_language가 비어있는 경우" }
      }
    },
    {
      "method": "PATCH",
      "path": "/sessions/{session_id}",
      "description": "세션 종료 (ended_at 갱신)",
      "procedure": [
        "경로 파라미터에서 session_id 추출",
        "UUID 형식 검증, 유효하지 않으면 400 반환",
        "DB에서 해당 session_id의 TranslationSession 조회",
        "세션이 존재하지 않으면 404 반환",
        "이미 ended_at이 설정되어 있으면 400 반환 (중복 종료 방지)",
        "ended_at을 현재 UTC 시각으로 UPDATE",
        "갱신된 세션 객체를 200 반환"
      ],
      "request": {
        "content_type": null,
        "fields": [],
        "path_params": [
          { "name": "session_id", "type": "uuid", "description": "세션 고유 식별자" }
        ]
      },
      "responses": {
        "200": {
          "description": "세션 종료 성공",
          "fields": [
            { "name": "id", "type": "uuid", "description": "세션 고유 식별자" },
            { "name": "source_language", "type": "string", "description": "원본 언어 코드" },
            { "name": "target_language", "type": "string", "description": "번역 대상 언어 코드" },
            { "name": "created_at", "type": "datetime", "description": "세션 생성 시각" },
            { "name": "ended_at", "type": "datetime", "description": "세션 종료 시각" }
          ]
        },
        "400": { "description": "UUID 형식 오류 또는 이미 종료된 세션" },
        "404": { "description": "세션이 존재하지 않는 경우" }
      }
    },
    {
      "method": "GET",
      "path": "/sessions/{session_id}",
      "description": "세션 상세 조회 (번역 로그 포함)",
      "procedure": [
        "경로 파라미터에서 session_id 추출",
        "UUID 형식 검증, 유효하지 않으면 400 반환",
        "DB에서 해당 session_id의 TranslationSession 조회",
        "세션이 존재하지 않으면 404 반환",
        "DB에서 해당 session_id의 TranslationLog를 created_at 오름차순으로 조회",
        "세션 정보 + 번역 로그 목록을 200 반환"
      ],
      "request": {
        "content_type": null,
        "fields": [],
        "path_params": [
          { "name": "session_id", "type": "uuid", "description": "세션 고유 식별자" }
        ]
      },
      "responses": {
        "200": {
          "description": "세션 상세 조회 성공",
          "fields": [
            { "name": "id", "type": "uuid", "description": "세션 고유 식별자" },
            { "name": "source_language", "type": "string", "description": "원본 언어 코드" },
            { "name": "target_language", "type": "string", "description": "번역 대상 언어 코드" },
            { "name": "created_at", "type": "datetime", "description": "세션 생성 시각" },
            { "name": "ended_at", "type": "datetime", "description": "세션 종료 시각 (null 가능)" },
            { "name": "logs", "type": "array", "description": "번역 로그 목록" }
          ]
        },
        "400": { "description": "UUID 형식 오류" },
        "404": { "description": "세션이 존재하지 않는 경우" }
      }
    },
    {
      "method": "POST",
      "path": "/sessions/{session_id}/logs",
      "description": "번역 로그 추가",
      "procedure": [
        "경로 파라미터에서 session_id 추출",
        "UUID 형식 검증, 유효하지 않으면 400 반환",
        "DB에서 해당 session_id의 TranslationSession 존재 여부 확인",
        "세션이 존재하지 않으면 404 반환",
        "요청 바디에서 original_text, translated_text, confidence 추출",
        "유효성 검증: original_text, translated_text가 비어있으면 400 반환",
        "유효성 검증: confidence가 제공된 경우 0.0~1.0 범위인지 확인",
        "created_at을 현재 UTC 시각으로 설정",
        "DB에 TranslationLog INSERT",
        "생성된 로그 객체를 201 반환"
      ],
      "request": {
        "content_type": "application/json",
        "fields": [
          {
            "name": "original_text",
            "type": "string",
            "required": true,
            "description": "원본 인식 텍스트"
          },
          {
            "name": "translated_text",
            "type": "string",
            "required": true,
            "description": "번역된 텍스트"
          },
          {
            "name": "confidence",
            "type": "float",
            "required": false,
            "description": "음성 인식 신뢰도 (0.0~1.0)"
          }
        ],
        "path_params": [
          { "name": "session_id", "type": "uuid", "description": "세션 고유 식별자" }
        ]
      },
      "responses": {
        "201": {
          "description": "로그 생성 성공",
          "fields": [
            { "name": "id", "type": "integer", "description": "로그 고유 식별자" },
            { "name": "session_id", "type": "uuid", "description": "세션 고유 식별자" },
            { "name": "original_text", "type": "string", "description": "원본 인식 텍스트" },
            { "name": "translated_text", "type": "string", "description": "번역된 텍스트" },
            { "name": "confidence", "type": "float", "description": "음성 인식 신뢰도 (null 가능)" },
            { "name": "created_at", "type": "datetime", "description": "기록 생성 시각" }
          ]
        },
        "400": { "description": "필수 필드 누락 또는 confidence 범위 초과" },
        "404": { "description": "세션이 존재하지 않는 경우" }
      }
    },
    {
      "method": "GET",
      "path": "/sessions/{session_id}/logs",
      "description": "세션의 번역 로그 목록 조회",
      "procedure": [
        "경로 파라미터에서 session_id 추출",
        "UUID 형식 검증, 유효하지 않으면 400 반환",
        "DB에서 해당 session_id의 TranslationSession 존재 여부 확인",
        "세션이 존재하지 않으면 404 반환",
        "DB에서 해당 session_id의 TranslationLog를 created_at 오름차순으로 조회",
        "로그 목록을 200 반환"
      ],
      "request": {
        "content_type": null,
        "fields": [],
        "path_params": [
          { "name": "session_id", "type": "uuid", "description": "세션 고유 식별자" }
        ]
      },
      "responses": {
        "200": {
          "description": "로그 목록 조회 성공",
          "fields": [
            {
              "name": "logs",
              "type": "array",
              "description": "번역 로그 목록",
              "items": {
                "fields": [
                  { "name": "id", "type": "integer", "description": "로그 고유 식별자" },
                  { "name": "session_id", "type": "uuid", "description": "세션 고유 식별자" },
                  { "name": "original_text", "type": "string", "description": "원본 인식 텍스트" },
                  { "name": "translated_text", "type": "string", "description": "번역된 텍스트" },
                  { "name": "confidence", "type": "float", "description": "음성 인식 신뢰도" },
                  { "name": "created_at", "type": "datetime", "description": "기록 생성 시각" }
                ]
              }
            }
          ]
        },
        "400": { "description": "UUID 형식 오류" },
        "404": { "description": "세션이 존재하지 않는 경우" }
      }
    },
    {
      "method": "GET",
      "path": "/health",
      "description": "서버 상태 확인",
      "procedure": [
        "서버 상태 ok 반환",
        "현재 UTC 시각을 타임스탬프로 포함"
      ],
      "request": {
        "content_type": null,
        "fields": []
      },
      "responses": {
        "200": {
          "description": "서버 정상",
          "fields": [
            { "name": "status", "type": "string", "description": "서버 상태 (ok)" },
            { "name": "timestamp", "type": "datetime", "description": "현재 서버 시각" }
          ]
        }
      }
    }
  ]
}
